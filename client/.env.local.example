# Config del SDK web de Firebase (proyecto: maxilus-dental).
# Se obtiene desde Firebase Console > Configuracion del proyecto > Tus apps > Web app.
# Copiar este archivo a .env.local (ignorado por git) y completar los valores.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=maxilus-dental.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=maxilus-dental
VITE_FIREBASE_STORAGE_BUCKET=maxilus-dental.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# En true, el cliente se conecta a los emuladores locales de Firebase
# en vez de al proyecto real (evita cualquier costo durante desarrollo).
VITE_USE_FIREBASE_EMULATORS=true
