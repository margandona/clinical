rules_version = '2';

// Cimientos: deny-all por defecto. Las reglas de acceso a
// radiografías/documentos (E17) se definen junto con el modelo
// de datos y roles.
service firebase.storage {
  match /b/{bucket}/o {
    // E-landing: imágenes de banners/destacados/alianzas/testimonios de la
    // home pública. Lectura pública (se muestran sin sesión); escritura
    // solo del admin de esa clínica, y solo imágenes de hasta 5MB.
    match /landing/{clinicaId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.token.rol == 'admin'
        && request.auth.token.clinicaId == clinicaId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
